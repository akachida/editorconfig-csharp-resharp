root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.cs]
# Tabs, indents, alignment
## General
indent_style = spaces
csharp_indent_style = spaces
resharper_csharp_indent_style = spaces
#-
indent_size = 4
csharp_indent_size = 4
resharper_csharp_indent_size = 4
#-
tab_width = 4
csharp_tab_width = 4
resharper_csharp_tab_width = 4
#-
continuous_indent_multiplier = 1
resharper_continuous_indent_multiplier = 1
csharp_continuous_indent_multiplier = 1
resharper_csharp_continuous_indent_multiplier = 1
#-
## Nested statements
indent_nested_usings_stmt = false
resharper_indent_nested_usings_stmt = false
csharp_indent_nested_usings_stmt = false
resharper_csharp_indent_nested_usings_stmt = false
#-
indent_nested_fixed_stmt = false
resharper_indent_nested_fixed_stmt = false
csharp_indent_nested_fixed_stmt = false
resharper_csharp_indent_nested_fixed_stmt = false
#-
indent_nested_lock_stmt = false
resharper_indent_nested_lock_stmt = false
csharp_indent_nested_lock_stmt = false
resharper_csharp_indent_nested_lock_stmt = false
#-
indent_nested_for_stmt = false
resharper_indent_nested_for_stmt = false
csharp_indent_nested_for_stmt = false
resharper_csharp_indent_nested_for_stmt = false
#-
indent_nested_foreach_stmt = false
resharper_indent_nested_foreach_stmt = false
csharp_indent_nested_foreach_stmt = false
resharper_csharp_indent_nested_foreach_stmt = false
#-
indent_nested_while_stmt = false
resharper_indent_nested_while_stmt = false
csharp_indent_nested_while_stmt = false
resharper_csharp_indent_nested_while_stmt = false
#-
## Parenthesis
use_continuous_indent_inside_parens = true
resharper_use_continuous_indent_inside_parens = true
csharp_use_continuous_indent_inside_parens = true
resharper_csharp_use_continuous_indent_inside_parens = true
#-
indent_method_decl_pars = inside
resharper_indent_method_decl_pars = inside
csharp_indent_method_decl_pars = inside
resharper_csharp_indent_method_decl_pars = inside
#-
indent_primary_constructor_decl_pars = inside
resharper_indent_primary_constructor_decl_pars = inside
csharp_indent_primary_constructor_decl_pars = inside
resharper_csharp_indent_primary_constructor_decl_pars = inside
#-
indent_invocation_pars = inside
resharper_indent_invocation_pars = inside
csharp_indent_invocation_pars = inside
resharper_csharp_indent_invocation_pars = inside
#-
indent_statement_pars = inside
resharper_indent_statement_pars = inside
csharp_indent_statement_pars = inside
resharper_csharp_indent_statement_pars = inside
#-
indent_typeparam_angles = inside
resharper_indent_typeparam_angles = inside
csharp_indent_typeparam_angles = inside
resharper_csharp_indent_typeparam_angles = inside
#-
indent_typearg_angles = inside
resharper_indent_typearg_angles = inside
csharp_indent_typearg_angles = inside
resharper_csharp_indent_typearg_angles = inside
#-
indent_pars = inside
resharper_indent_pars = inside
csharp_indent_pars = inside
resharper_csharp_indent_pars = inside
#-
## Preprocessor directives
indent_preprocessor_if = no_indent
resharper_indent_preprocessor_if = no_indent
csharp_indent_preprocessor_if = no_indent
resharper_csharp_indent_preprocessor_if = no_indent
#-
indent_preprocessor_region = usual_indent
resharper_indent_preprocessor_region = usual_indent
csharp_indent_preprocessor_region = usual_indent
resharper_csharp_indent_preprocessor_region = usual_indent
#-
indent_preprocessor_other = no_indent
resharper_indent_preprocessor_other = no_indent
csharp_indent_preprocessor_other = no_indent
resharper_csharp_indent_preprocessor_other = no_indent
#-
## Other indents
indent_switch_labels = true
resharper_indent_switch_labels = true
csharp_indent_switch_labels = true
resharper_csharp_indent_switch_labels = true
#-
indent_break_from_case = false
resharper_indent_break_from_case = false
csharp_indent_break_from_case = false
resharper_csharp_indent_break_from_case = false
#-
outdent_statement_labels = false
resharper_outdent_statement_labels = false
csharp_outdent_statement_labels = false
resharper_csharp_outdent_statement_labels = false
#-
indent_type_constraints = false
resharper_indent_type_constraints = false
csharp_indent_type_constraints = false
resharper_csharp_indent_type_constraints = false
